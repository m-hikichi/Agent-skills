{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-skills.local/marp-slide/run-state.schema.json",
  "title": "Marp slide run state",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "run_id",
    "status",
    "completed",
    "started_at",
    "updated_at",
    "artifact_fingerprint",
    "review_attempt",
    "render_iteration",
    "message"
  ],
  "properties": {
    "schema_version": { "const": 1 },
    "run_id": { "type": "string", "pattern": "^[a-f0-9-]{36}$" },
    "status": { "enum": ["active", "needs_user", "blocked", "complete"] },
    "completed": { "type": "boolean" },
    "started_at": { "type": "string", "format": "date-time" },
    "updated_at": { "type": "string", "format": "date-time" },
    "artifact_fingerprint": {
      "anyOf": [
        { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        { "type": "null" }
      ]
    },
    "review_attempt": { "type": "integer", "minimum": 0 },
    "render_iteration": { "type": "integer", "minimum": 0 },
    "message": { "type": ["string", "null"] }
  }
}
